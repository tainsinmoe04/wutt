+@router.post("/chat")
+def chat_with_stylist(
+    body: ChatRequest,
+    db: Session = Depends(get_db),
+    current_user: User = Depends(get_current_user),
+) -> AuthResponse:
+    """General chat with the AI stylist.
+
+    Handles greetings, fashion questions, WUTT explanations, and casual chat.
+    For specific outfit requests, use /stylist/recommend instead.
+    """
+    user_id = current_user.id
+    message = body.message.strip()
+
+    logger.info(
+        "POST /stylist/chat — user_id=%d message_length=%d",
+        user_id, len(message),
+    )
+
+    # Fetch user context
+    profile = db.query(Profile).filter(Profile.user_id == user_id).first()
+    items = (
+        db.query(Wardrobe)
+        .filter(Wardrobe.user_id == user_id)
+        .all()
+    )
+
+    # Build wardrobe context for Gemini
+    wardrobe_context: list[dict[str, Any]] = []
+    for item in items[:15]:  # Limit to 15 items for context
+        wardrobe_context.append({
+            "category": item.category,
+            "color": item.color,
+            "description": item.description,
+        })
+
+    # Try Gemini for chat
+    source = "fallback"
+    response_text: str | None = None
+
+    if settings.gemini_api_key:
+        try:
+            response_text = get_chat_response(
+                user_message=message,
+                conversation_history=body.conversation_history,
+                wardrobe_items=wardrobe_context if wardrobe_context else None,
+            )
+            if response_text:
+                source = "gemini"
+                print(f"[WUTT] ✓ Gemini chat responded — {len(response_text)} chars")
+        except Exception as exc:
+            cls = type(exc).__qualname__
+            mod = type(exc).__module__
+            print(f"[WUTT] ✗ Gemini chat error: {mod}.{cls}")
+            logger.warning("Gemini chat failed: %s.%s", mod, cls)
+
+    # Fallback response if Gemini failed
+    if not response_text:
+        source = "fallback"
+        response_text = _fallback_chat_response(message, wardrobe_context)
+
+    # Save to session history
+    session = StyleSession(
+        user_id=user_id,
+        occasion="chat",
+        weather_desc=None,
+        temperature_c=None,
+        location=None,
+        ai_response=json.dumps({
+            "message": message,
+            "response": response_text,
+            "source": source,
+        }, ensure_ascii=False),
+    )
+    db.add(session)
+    db.commit()
+
+    return {
+        "status": "success",
+        "data": {
+            "response": response_text,
+            "source": source,
+        },
+        "message": "Chat response generated.",
+    }
+
+
+def _fallback_chat_response(message: str, wardrobe_items: list[dict[str, Any]]) -> str:
+    """Provide a helpful fallback response when Gemini is unavailable."""
+    msg_lower = message.lower().strip()
+
+    # Greetings
+    if any(w in msg_lower for w in ("hi", "hey", "hello", "helo", "ဟိုင်း", "ဟေ့")):
+        return (
+            "Hey! 👋 I'm your WUTT fashion companion. "
+            "What can I help you with today? "
+            "Ask me about outfit ideas, style tips, or how to use the app."
+        )
+
+    # WUTT explanation
+    if any(w in msg_lower for w in ("wutt", "what is", "how to use", "app", "ဘာလဲ", "ဘယ်လိုသုံး")):
+        return (
+            "WUTT is your AI fashion companion! 📱\n\n"
+            "Here's what you can do:\n"
+            "• Upload your wardrobe items (photos of your clothes)\n"
+            "• Get outfit recommendations for any occasion\n"
+            "• Ask me fashion questions anytime\n"
+            "• Save looks you love\n\n"
+            "Try saying 'What should I wear to a coffee date?' to get started!"
+        )
+
+    # Fashion questions
+    if any(w in msg_lower for w in ("what to wear", "outfit", "dress", "style", "fashion", "ဝတ်")):
+        return (
+            "I'd love to help you find the perfect outfit! 🎨\n\n"
+            "Tell me:\n"
+            "• What's the occasion? (coffee date, work, wedding, casual)\n"
+            "• Any weather preferences?\n\n"
+            "Or just say something like 'What should I wear to a wedding?' and I'll help!"
+        )
+
+    # Default
+    return (
+        "Hey! I'm here to help with fashion and style. 😊\n\n"
+        "You can ask me:\n"
+            "• 'What should I wear to a coffee date?'\n"
+            "• 'How do I use WUTT?'\n"
+            "• 'Give me style tips for summer'\n\n"
+        "What would you like to know?"
+    )
+
