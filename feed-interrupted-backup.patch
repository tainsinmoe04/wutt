+  cursor: pointer;
+  color: var(--wutt-text-muted);
+  transition: all var(--transition-fast);
+  line-height: 1;
+}
+.modal__close:hover { background: rgba(10, 10, 10, 0.06); color: var(--wutt-text); }
+.modal__close:focus-visible { outline: 3px solid var(--wutt-deep); outline-offset: 2px; }
+
+.modal__body {
+  padding: var(--space-xl);
+  display: flex; flex-direction: column; gap: var(--space-md);
+}
+
+.modal__footer {
+  padding: 0 var(--space-xl) var(--space-xl);
+  display: flex; flex-direction: column; gap: var(--space-md);
+}
+
+.modal__switch {
+  text-align: center;
+  font-size: var(--text-sm);
+  color: var(--wutt-text-light);
+}
+.modal__switch a, .modal__switch button {
+  color: var(--wutt-dark);
+  font-weight: 600;
+  cursor: pointer;
+}
+.modal__switch a:hover, .modal__switch button:hover { color: var(--wutt-primary); }
+
+/* --------------------------------------------------------
+   Toast Notifications
+   -------------------------------------------------------- */
+.toast-container {
+  position: fixed;
+  bottom: var(--space-lg); right: var(--space-lg);
+  z-index: var(--z-toast);
+  display: flex; flex-direction: column; gap: var(--space-sm);
+  max-width: 380px; width: 100%;
+  pointer-events: none;
+}
+.toast {
+  display: flex; align-items: flex-start; gap: var(--space-sm);
+  padding: var(--space-md) var(--space-lg);
+  border-radius: var(--radius-lg);
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border);
+  box-shadow: var(--shadow-lg);
+  font-size: var(--text-sm); font-weight: 500;
+  pointer-events: auto;
+  animation: slideInRight 0.3s ease-out, fadeOut 0.3s ease-out forwards;
+  animation-delay: 0s, 3.7s;
+}
+.toast--success { border-left: 4px solid var(--wutt-success); color: #065F46; }
+.toast--error   { border-left: 4px solid var(--wutt-error);   color: #991B1B; }
+.toast--info    { border-left: 4px solid var(--wutt-info);    color: #1E40AF; }
+.toast--warning { border-left: 4px solid var(--wutt-warning); color: #92400E; }
+
+@keyframes slideInRight {
+  from { opacity: 0; transform: translateX(100%); }
+  to   { opacity: 1; transform: translateX(0); }
+}
+@keyframes fadeOut {
+  to { opacity: 0; transform: translateY(-8px); }
+}
+
+/* --------------------------------------------------------
+   Skeleton Loading
+   -------------------------------------------------------- */
+.skeleton {
+  position: relative;
+  background: var(--wutt-bg-subtle);
+  border-radius: var(--radius-sm);
+  color: transparent !important;
+  user-select: none; pointer-events: none;
+  overflow: hidden;
+}
+.skeleton::after {
+  content: '';
+  position: absolute; inset: 0;
+  background: linear-gradient(90deg, transparent 0%, rgba(136, 162, 255, 0.08) 50%, transparent 100%);
+  animation: shimmer 1.5s ease-in-out infinite;
+  will-change: transform;
+}
+.skeleton--text { height: 1em; margin-bottom: 0.5em; }
+.skeleton--title { height: 1.5em; width: 60%; margin-bottom: 1em; }
+.skeleton--avatar { width: 48px; height: 48px; border-radius: var(--radius-full); }
+.skeleton--card { height: 200px; border-radius: var(--radius-xl); }
+.skeleton--form-field { height: var(--input-height); border-radius: var(--radius-md); margin-bottom: var(--space-md); }
+.skeleton--btn { height: var(--btn-height); border-radius: var(--radius-lg); margin-top: var(--space-lg); }
+
+@keyframes shimmer {
+  0%   { transform: translateX(-100%); }
+  100% { transform: translateX(100%); }
+}
+
+/* --------------------------------------------------------
+   Error Card
+   -------------------------------------------------------- */
+.error-card {
+  display: flex; flex-direction: column;
+  align-items: center; gap: var(--space-md);
+  text-align: center;
+  padding: var(--space-2xl) var(--space-lg);
+  background: var(--wutt-error-bg);
+  border: 1px solid var(--wutt-error-border);
+  border-radius: var(--radius-xl);
+}
+.error-card__icon { font-size: 2rem; opacity: 0.7; }
+.error-card__text {
+  font-size: var(--text-sm);
+  color: var(--wutt-error);
+  font-weight: 500;
+  max-width: 280px;
+  line-height: 1.6;
+}
+.error-card__retry {
+  display: inline-flex; align-items: center; gap: var(--space-xs);
+  padding: var(--space-sm) var(--space-lg);
+  font-family: inherit; font-size: var(--text-sm); font-weight: 600;
+  color: var(--wutt-error);
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-error-border);
+  border-radius: var(--radius-md);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+}
+.error-card__retry:hover { background: var(--wutt-error); color: white; border-color: var(--wutt-error); }
+
+/* --------------------------------------------------------
+   Empty State
+   -------------------------------------------------------- */
+.empty-state--visual {
+  display: flex; flex-direction: column;
+  align-items: center; justify-content: center;
+  gap: var(--space-md);
+  padding: var(--space-3xl) var(--space-lg);
+  text-align: center;
+  border: 2px dashed var(--wutt-border);
+  border-radius: var(--radius-xl);
+  background: var(--wutt-bg-subtle);
+  min-height: 180px;
+}
+.empty-state--visual .empty-state__icon { font-size: 2.5rem; opacity: 0.4; margin-bottom: var(--space-sm); }
+.empty-state--visual .empty-state__title { font-size: var(--text-base); font-weight: 600; color: var(--wutt-text); }
+.empty-state--visual .empty-state__hint { font-size: var(--text-xs); color: var(--wutt-text-muted); max-width: 260px; line-height: 1.6; }
+
+/* --------------------------------------------------------
+   Upload Success
+   -------------------------------------------------------- */
+.upload-success {
+  display: flex; align-items: center; gap: var(--space-sm);
+  padding: var(--space-sm) var(--space-md);
+  background: var(--wutt-success-bg);
+  border: 1px solid var(--wutt-success-border);
+  border-radius: var(--radius-md);
+  color: #065F46;
+  font-size: var(--text-sm); font-weight: 600;
+  animation: slideUp 0.3s ease-out;
+  margin-top: var(--space-sm);
+}
+.upload-success__check {
+  width: 20px; height: 20px;
+  background: var(--wutt-success);
+  border-radius: 50%;
+  display: flex; align-items: center; justify-content: center;
+  flex-shrink: 0;
+  animation: checkPop 0.4s ease-out;
+}
+@keyframes checkPop {
+  0% { transform: scale(0); }
+  60% { transform: scale(1.3); }
+  100% { transform: scale(1); }
+}
+
+/* --------------------------------------------------------
+   File Preview Card
+   -------------------------------------------------------- */
+.preview-card {
+  display: flex; align-items: center; gap: var(--space-md);
+  padding: var(--space-md);
+  background: var(--wutt-bg-subtle);
+  border: 1px solid var(--wutt-border);
+  border-radius: var(--radius-md);
+  animation: slideUp 0.3s ease-out;
+}
+.preview-card__img { width: 64px; height: 64px; object-fit: cover; border-radius: var(--radius-sm); flex-shrink: 0; }
+.preview-card__info { flex: 1; min-width: 0; }
+.preview-card__name { font-size: var(--text-sm); font-weight: 600; color: var(--wutt-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
+.preview-card__size { font-size: var(--text-xs); color: var(--wutt-text-muted); margin-top: 2px; }
+.preview-card__remove {
+  display: flex; align-items: center; justify-content: center;
+  min-width: 32px; min-height: 32px;
+  background: none; border: 1px solid var(--wutt-border); border-radius: 50%;
+  cursor: pointer; color: var(--wutt-text-muted); font-size: 18px;
+  transition: all var(--transition-fast); flex-shrink: 0;
+}
+.preview-card__remove:hover { background: var(--wutt-error-bg); border-color: var(--wutt-error); color: var(--wutt-error); }
+
+/* --------------------------------------------------------
+   Outfit Card — AI recommendation
+   -------------------------------------------------------- */
+.outfit-card {
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border-light);
+  border-radius: var(--radius-xl);
+  padding: var(--space-lg);
+  box-shadow: none;
+}
+.outfit-card + .outfit-card { margin-top: var(--space-md); }
+.outfit-card--context {
+  background: linear-gradient(135deg, rgba(136,162,255,0.04), rgba(171,157,255,0.03));
+  border: none;
+}
+.outfit-card__step {
+  display: flex; align-items: flex-start; gap: var(--space-md);
+  padding: var(--space-md) 0;
+}
+.outfit-card__step + .outfit-card__step { border-top: 1px solid var(--wutt-border-light); }
+.outfit-card__number {
+  display: flex; align-items: center; justify-content: center;
+  min-width: 28px; height: 28px;
+  background: var(--wutt-dark);
+  color: var(--wutt-light);
+  border-radius: 50%;
+  font-size: var(--text-xs); font-weight: 700;
+  flex-shrink: 0;
+}
+.outfit-card__label { font-size: var(--text-sm); font-weight: 500; color: var(--wutt-text); line-height: 1.5; }
+.outfit-card--tip {
+  display: flex; align-items: flex-start; gap: var(--space-sm);
+  background: rgba(227,252,135,0.1);
+  border: 1px solid rgba(227,252,135,0.25);
+}
+.outfit-card--tip .tip-icon { font-size: 1.125rem; flex-shrink: 0; margin-top: 1px; }
+
+/* --------------------------------------------------------
+   Alert Messages
+   -------------------------------------------------------- */
+.alert {
+  display: flex; align-items: flex-start; gap: var(--space-sm);
+  padding: var(--space-md) var(--space-lg);
+  border-radius: var(--radius-md);
+  font-size: var(--text-sm); font-weight: 500; line-height: 1.5;
+}
+.alert--error   { background: var(--wutt-error-bg);   color: var(--wutt-error);   border: 1px solid var(--wutt-error-border); }
+.alert--success { background: var(--wutt-success-bg); color: #065F46;            border: 1px solid var(--wutt-success-border); }
+.alert--info    { background: var(--wutt-info-bg);    color: var(--wutt-info);    border: 1px solid #BFDBFE; }
+.alert--warning { background: var(--wutt-warning-bg); color: #92400E;            border: 1px solid #FDE68A; }
+
+/* --------------------------------------------------------
+   Loader / Spinner
+   -------------------------------------------------------- */
+.spinner {
+  display: inline-block;
+  width: 20px; height: 20px;
+  border: 2px solid var(--wutt-border);
+  border-top-color: var(--wutt-primary);
+  border-radius: 50%;
+  animation: spin 0.6s linear infinite;
+}
+.spinner--sm { width: 14px; height: 14px; border-width: 1.5px; }
+.spinner--lg { width: 36px; height: 36px; border-width: 3px; }
+
+/* --------------------------------------------------------
+   Footer
+   -------------------------------------------------------- */
+.footer {
+  text-align: center;
+  padding: var(--space-xl) var(--space-lg);
+  color: var(--wutt-text-muted);
+  font-size: var(--text-xs);
+  border-top: 1px solid var(--wutt-border-light);
+}
+
+/* --------------------------------------------------------
+   Keyframe Animations
+   -------------------------------------------------------- */
+@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
+@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
+@keyframes slideDown { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: translateY(0); } }
+@keyframes spin { to { transform: rotate(360deg); } }
+@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
+
+.animate--fade-in  { animation: fadeIn 0.5s ease-out; }
+.animate--slide-up { animation: slideUp 0.5s ease-out; }
+
+.stagger > * {
+  opacity: 0;
+  animation: slideUp 0.5s ease-out forwards;
+}
+.stagger > *:nth-child(1) { animation-delay: 0.1s; }
+.stagger > *:nth-child(2) { animation-delay: 0.2s; }
+.stagger > *:nth-child(3) { animation-delay: 0.3s; }
+.stagger > *:nth-child(4) { animation-delay: 0.4s; }
+.stagger > *:nth-child(5) { animation-delay: 0.5s; }
+.stagger > *:nth-child(6) { animation-delay: 0.6s; }
+
+/* --------------------------------------------------------
+   Accessibility — Reduced Motion
+   -------------------------------------------------------- */
+@media (prefers-reduced-motion: reduce) {
+  *, *::before, *::after {
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+    scroll-behavior: auto !important;
+  }
+  .hero__stagger-1,
+  .hero__stagger-2,
+  .hero__stagger-3,
+  .hero__stagger-4,
+  .hero__stagger-5,
+  .landing-hero__stagger-1,
+  .landing-hero__stagger-2,
+  .landing-hero__stagger-3 {
+    opacity: 1;
+    transform: none;
+    animation: none;
+  }
+  .login-card {
+    transform: none;
+    opacity: 1;
+  }
+  .stagger > * { opacity: 1; animation: none; }
+  }
+
+
+/* --------------------------------------------------------
+   Utility Classes
+   -------------------------------------------------------- */
+.u-sr-only {
+  position: absolute;
+  width: 1px; height: 1px; padding: 0; margin: -1px;
+  overflow: hidden; clip: rect(0, 0, 0, 0);
+  white-space: nowrap; border-width: 0;
+}
+.u-hidden { display: none !important; }
+.u-flex            { display: flex; }
+.u-flex-col        { flex-direction: column; }
+.u-items-center    { align-items: center; }
+.u-items-start     { align-items: flex-start; }
+.u-justify-center  { justify-content: center; }
+.u-justify-between { justify-content: space-between; }
+.u-text-center     { text-align: center; }
+.u-gap-sm          { gap: var(--space-sm); }
+.u-gap-md          { gap: var(--space-md); }
+.u-gap-lg          { gap: var(--space-lg); }
+.u-mt-sm           { margin-top: var(--space-sm); }
+.u-mt-md           { margin-top: var(--space-md); }
+.u-mt-lg           { margin-top: var(--space-lg); }
+.u-mb-md           { margin-bottom: var(--space-md); }
+.u-mb-lg           { margin-bottom: var(--space-lg); }
+.u-w-full          { width: 100%; }
+
+/* --------------------------------------------------------
+   Focus styles
+   -------------------------------------------------------- */
+a:focus-visible,
+button:focus-visible,
+input:focus-visible,
+select:focus-visible,
+textarea:focus-visible,
+[tabindex]:focus-visible {
+  outline: 3px solid var(--wutt-deep);
+  outline-offset: 2px;
+}
+
+/* --------------------------------------------------------
+   Mobile Responsive
+   -------------------------------------------------------- */
+@media (max-width: 840px) {
+  :root {
+    --space-lg: 1rem; --space-xl: 1.5rem;
+    --space-2xl: 2rem; --space-3xl: 2.5rem; --space-4xl: 3rem;
+  }
+
+  .hero__inner {
+    grid-template-columns: 1fr;
+    gap: var(--space-2xl);
+    text-align: center;
+  }
+  .hero__content { max-width: 100%; }
+  .hero__actions { justify-content: center; }
+  .hero__visual { order: 2; max-width: 480px; margin: 0 auto; }
+  .how-it-works__grid { grid-template-columns: 1fr; max-width: 400px; }
+
+  .navbar__nav {
+    position: fixed;
+    top: 0; right: -100%;
+    width: 280px; height: 100vh; height: 100dvh;
+    flex-direction: column;
+    background: var(--wutt-light);
+    padding: var(--space-3xl) var(--space-xl);
+    box-shadow: var(--shadow-xl);
+    transition: right var(--transition-base);
+    gap: var(--space-md);
+  }
+  .navbar__nav--open { right: 0; }
+  .navbar__toggle { display: flex; align-items: center; justify-content: center; }
+
+  .hero { padding: calc(var(--space-2xl) + 60px) var(--space-md) var(--space-3xl); }
+  .hero__headline { font-size: clamp(1.75rem, 7vw, 2.5rem); }
+  .hero__actions { flex-direction: column; width: 100%; }
+  .hero__actions .btn { width: 100%; }
+
+  .modal { max-width: 100%; margin: var(--space-lg); max-height: calc(100dvh - var(--space-2xl)); }
+
+  .dashboard { padding-top: 70px; }
+  .dashboard__grid { grid-template-columns: 1fr; padding: var(--space-md); }
+
+  .toast-container { left: var(--space-md); right: var(--space-md); max-width: 100%; }
+
+  /* Landing hero mobile */
+  .landing-hero__content {
+    padding: var(--space-2xl) var(--space-md);
+  }
+  .landing-hero__wordmark {
+    font-size: 2.5rem;
+  }
+  .landing-hero__headline {
+    font-size: 1.5rem;
+  }
+  .login-card {
+    padding: var(--space-lg) var(--space-lg) var(--space-md);
+  }
+}
+
+@media (max-width: 480px) {
+  .hero { padding: calc(var(--space-xl) + 60px) var(--space-md) var(--space-2xl); }
+  .hero__headline { font-size: 1.75rem; }
+  .preview { max-width: 100%; }
+  .how-it-works { padding: var(--space-2xl) var(--space-md); }
+
+  .navbar__inner { padding: 0 var(--space-md); }
+  .card { padding: var(--space-lg); }
+  .modal__body, .modal__header, .modal__footer { padding-left: var(--space-lg); padding-right: var(--space-lg); }
+
+  /* Landing hero small mobile */
+  .landing-hero__content {
+    padding: var(--space-xl) var(--space-md);
+  }
+  .landing-hero__wordmark {
+    font-size: 2rem;
+  }
+  .landing-hero__headline {
+    font-size: 1.35rem;
+  }
+  .login-card {
+    max-width: 100%;
+    padding: var(--space-lg) var(--space-md) var(--space-md);
+  }
+}
+
+
+/* --------------------------------------------------------
+Welcome Loading Screen — Editorial fashion intro
+-------------------------------------------------------- */
+.welcome-screen {
+  position: fixed;
+  inset: 0;
+  z-index: var(--z-modal);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: var(--wutt-bg);
+}
+
+.welcome-screen__inner {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  text-align: center;
+  gap: var(--space-sm);
+}
+
+/* Wordmark — appears first, fades up */
+.welcome-screen__wordmark {
+  font-size: 0.6875rem;
+  font-weight: 700;
+  letter-spacing: 3px;
+  text-transform: uppercase;
+  color: var(--wutt-text-muted);
+  margin-bottom: var(--space-sm);
+  opacity: 0;
+  animation: welcomeWordmarkIn 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
+  animation-delay: 0.25s;
+}
+
+@keyframes welcomeWordmarkIn {
+  0%   { opacity: 0; transform: translateY(12px); letter-spacing: 6px; }
+  100% { opacity: 0.8; transform: translateY(0); letter-spacing: 3px; }
+}
+
+/* Title — appears second, gentle scale+fade */
+.welcome-screen__title {
+  font-size: clamp(1.5rem, 3.5vw, 2rem);
+  font-weight: 700;
+  color: var(--wutt-dark);
+  letter-spacing: -0.03em;
+  opacity: 0;
+  animation: welcomeTitleIn 0.9s cubic-bezier(0.23, 1, 0.32, 1) forwards;
+  animation-delay: 0.8s;
+}
+
+@keyframes welcomeTitleIn {
+  0%   { opacity: 0; transform: translateY(16px) scale(0.96); }
+  100% { opacity: 1; transform: translateY(0) scale(1); }
+}
+
+/* Subtitle — subtle final step */
+.welcome-screen__subtitle {
+  font-size: var(--text-xs);
+  color: var(--wutt-text-muted);
+  max-width: 260px;
+  line-height: 1.5;
+  opacity: 0;
+  animation: welcomeSubIn 0.7s ease-out forwards;
+  animation-delay: 1.5s;
+}
+
+@keyframes welcomeSubIn {
+  0%   { opacity: 0; transform: translateY(8px); }
+  100% { opacity: 0.5; transform: translateY(0); }
+}
+
+/* Hide loader dots — not needed with word animations */
+.welcome-screen__loader {
+  display: none;
+}
+
+/* --------------------------------------------------------
+Chat App — Main screen (redesign)
+-------------------------------------------------------- */
+.chat-app {
+  position: fixed;
+  inset: 0;
+  z-index: var(--z-overlay);
+  display: flex;
+  background: var(--wutt-bg);
+  overflow: hidden;
+}
+
+/* ---- Slim left sidebar ---- */
+.chat-sidebar {
+  width: 64px;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 6px;
+  padding: var(--space-md) 0;
+  background: var(--wutt-light);
+  border-right: 1px solid var(--wutt-border-light);
+  flex-shrink: 0;
+  z-index: 1;
+}
+
+.chat-sidebar__logo {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 40px;
+  height: 40px;
+  border-radius: var(--radius-md);
+  color: var(--wutt-dark);
+  margin-bottom: var(--space-md);
+  transition: background var(--transition-fast);
+}
+.chat-sidebar__logo:hover { background: var(--wutt-bg-subtle); }
+
+.chat-sidebar__item {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 40px;
+  height: 40px;
+  border-radius: var(--radius-md);
+  border: none;
+  background: transparent;
+  color: var(--wutt-text-muted);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+  position: relative;
+}
+.chat-sidebar__item:hover {
+  color: var(--wutt-text);
+  background: var(--wutt-bg-subtle);
+}
+.chat-sidebar__item--active {
+  color: var(--wutt-dark);
+  background: rgba(136, 162, 255, 0.1);
+}
+
+.chat-sidebar__spacer { flex: 1; }
+
+/* ---- Main chat area ---- */
+.chat-main {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  min-width: 0;
+}
+
+/* Chat header */
+.chat-header {
+  display: flex;
+  align-items: center;
+  gap: var(--space-md);
+  padding: var(--space-md) var(--space-xl);
+  background: rgba(255, 255, 255, 0.7);
+  backdrop-filter: blur(14px);
+  -webkit-backdrop-filter: blur(14px);
+  border-bottom: 1px solid var(--wutt-border-light);
+  flex-shrink: 0;
+}
+
+.chat-header__ai-icon {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+}
+
+.chat-header__text {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+}
+
+.chat-header__title {
+  font-size: var(--text-md);
+  font-weight: 700;
+  color: var(--wutt-dark);
+  letter-spacing: -0.02em;
+  line-height: 1.2;
+}
+
+.chat-header__subtitle {
+  font-size: 0.6875rem;
+  color: var(--wutt-text-muted);
+  font-weight: 500;
+  letter-spacing: 0.01em;
+}
+
+/* Chat body — scrollable area */
+.chat-body {
+  flex: 1;
+  overflow-y: auto;
+  -webkit-overflow-scrolling: touch;
+}
+
+/* ---- Welcome / empty state ---- */
+.chat-welcome {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  text-align: center;
+  padding: var(--space-4xl) var(--space-lg);
+  min-height: 100%;
+}
+
+.chat-welcome__avatar {
+  margin-bottom: var(--space-lg);
+  opacity: 0.9;
+}
+
+.chat-welcome__greeting {
+  font-size: clamp(1.25rem, 2.5vw, 1.625rem);
+  font-weight: 700;
+  color: var(--wutt-dark);
+  letter-spacing: -0.025em;
+  margin-bottom: var(--space-xs);
+  line-height: 1.3;
+}
+
+.chat-welcome__hint {
+  font-size: var(--text-sm);
+  color: var(--wutt-text-light);
+  margin-bottom: var(--space-2xl);
+  line-height: 1.5;
+}
+
+/* Action cards grid */
+.chat-welcome__cards {
+  display: grid;
+  grid-template-columns: repeat(2, 1fr);
+  gap: var(--space-sm);
+  width: 100%;
+  max-width: 420px;
+}
+
+/* Action card */
+.action-card {
+  display: flex;
+  flex-direction: column;
+  align-items: flex-start;
+  gap: var(--space-xs);
+  padding: var(--space-lg);
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border-light);
+  border-radius: var(--radius-lg);
+  cursor: pointer;
+  transition: all 0.25s cubic-bezier(0.23, 1, 0.32, 1);
+  text-align: left;
+  font-family: inherit;
+}
+.action-card:hover {
+  transform: translateY(-3px);
+  box-shadow: var(--shadow-lg);
+  border-color: var(--wutt-primary);
+}
+.action-card:active { transform: scale(0.98); }
+
+.action-card__icon {
+  color: var(--wutt-primary);
+  margin-bottom: var(--space-xs);
+}
+
+.action-card__label {
+  font-size: var(--text-sm);
+  font-weight: 700;
+  color: var(--wutt-dark);
+  letter-spacing: -0.01em;
+}
+
+.action-card__desc {
+  font-size: 0.6875rem;
+  color: var(--wutt-text-muted);
+  line-height: 1.4;
+}
+
+/* ---- Messages (hidden until interaction) ---- */
+.chat-messages {
+  padding: var(--space-lg);
+  display: flex;
+  flex-direction: column;
+  gap: var(--space-md);
+  align-items: flex-start;
+}
+
+.chat-msg {
+  display: flex;
+  gap: var(--space-sm);
+  max-width: 82%;
+  animation: chatMsgIn 0.35s ease-out;
+}
+
+/* Cap standalone cards/chips to chat-bubble width so they don't stretch full screen */
+.chat-chips,
+.upload-card,
+.describe-form,
+.analyzing-card {
+  max-width: 82%;
+  width: fit-content;
+  min-width: 340px;
+}
+
+/* Analysis card — align like a bot message, compact */
+.analysis-card {
+  max-width: 560px;
+  width: fit-content;
+  min-width: 320px;
+}
+
+@keyframes chatMsgIn {
+  from { opacity: 0; transform: translateY(8px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+.chat-msg--bot { align-self: flex-start; }
+
+.chat-msg__avatar {
+  width: 32px;
+  height: 32px;
+  flex-shrink: 0;
+  align-self: flex-end;
+}
+
+.chat-msg__bubble {
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border-light);
+  border-radius: 20px 20px 20px 6px;
+  padding: var(--space-sm) var(--space-md);
+  font-size: var(--text-sm);
+  color: var(--wutt-text);
+  line-height: 1.6;
+  box-shadow: var(--shadow-xs);
+}
+
+/* Chat chips */
+.chat-chips {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--space-sm);
+  padding-left: 40px;
+}
+
+.chat-chip {
+  display: inline-flex;
+  align-items: center;
+  padding: 0.45rem 1rem;
+  font-family: inherit;
+  font-size: var(--text-xs);
+  font-weight: 600;
+  color: var(--wutt-text);
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border);
+  border-radius: var(--radius-full);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+  touch-action: manipulation;
+}
+.chat-chip:hover {
+  background: var(--wutt-dark);
+  color: var(--wutt-light);
+  border-color: var(--wutt-dark);
+  box-shadow: var(--shadow-md);
+}
+.chat-chip:active { transform: scale(0.97); }
+
+/* ---- Input bar ---- */
+.chat-input-bar {
+  padding: var(--space-sm) var(--space-lg) var(--space-md);
+  flex-shrink: 0;
+  display: flex;
+  justify-content: center;
+}
+
+.chat-input__wrapper {
+  display: flex;
+  align-items: center;
+  gap: var(--space-xs);
+  background: var(--wutt-light);
+  border: 1.5px solid var(--wutt-border);
+  border-radius: var(--radius-2xl);
+  padding: 2px;
+  transition: all var(--transition-fast);
+  box-shadow: var(--shadow-xs);
+  max-width: 680px;
+  width: 100%;
+}
+/* Remove default outline on raw input — wrapper handles focus visuals */
+.chat-input__field:focus,
+.chat-input__field:focus-visible {
+  outline: none;
+  box-shadow: none;
+}
+.chat-input__wrapper:focus-within {
+  border-color: var(--wutt-primary);
+  box-shadow: 0 0 0 3px rgba(200, 155, 142, 0.15);
+}
+
+.chat-input__attach {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 38px;
+  height: 38px;
+  min-width: 38px;
+  border-radius: var(--radius-full);
+  border: none;
+  background: transparent;
+  color: var(--wutt-text-muted);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+}
+.chat-input__attach:hover:not(:disabled) { color: var(--wutt-text); background: var(--wutt-bg-subtle); }
+.chat-input__attach:disabled { opacity: 0.3; cursor: not-allowed; }
+
+.chat-input__field {
+  flex: 1;
+  height: 40px;
+  border: none;
+  background: transparent;
+  font-family: inherit;
+  font-size: var(--text-sm);
+  color: var(--wutt-text);
+  outline: none;
+  padding: 0 var(--space-xs);
+}
+.chat-input__field::placeholder { color: var(--wutt-text-muted); }
+
+.chat-input__send {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 38px;
+  height: 38px;
+  min-width: 38px;
+  border-radius: var(--radius-full);
+  border: none;
+  background: var(--wutt-dark);
+  color: var(--wutt-light);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+}
+.chat-input__send:hover {
+  background: #2A2A2A;
+  transform: scale(1.05);
+}
+.chat-input__send:active { transform: scale(0.95); }
+.chat-input__send:disabled {
+  background: var(--wutt-bg-subtle);
+  color: var(--wutt-text-muted);
+  cursor: not-allowed;
+  transform: none;
+}
+
+/* ---- User message bubble ---- */
+.chat-msg--user {
+  align-self: flex-end;
+}
+.chat-msg--user .chat-msg__bubble {
+  background: var(--wutt-dark);
+  color: var(--wutt-light);
+  border: none;
+  border-radius: 20px 20px 6px 20px;
+}
+
+/* ---- Upload preview card (in chat) ---- */
+.upload-card {
+  display: flex;
+  align-items: center;
+  gap: var(--space-md);
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border-light);
+  border-radius: var(--radius-lg);
+  padding: var(--space-md);
+  margin-top: var(--space-sm);
+  box-shadow: var(--shadow-xs);
+  animation: chatMsgIn 0.35s ease-out;
+}
+.upload-card__thumb {
+  width: 56px;
+  height: 56px;
+  border-radius: var(--radius-sm);
+  object-fit: cover;
+  flex-shrink: 0;
+  background: var(--wutt-bg-subtle);
+}
+.upload-card__info {
+  flex: 1;
+  min-width: 0;
+}
+.upload-card__name {
+  font-size: var(--text-xs);
+  font-weight: 600;
+  color: var(--wutt-text);
+  margin-bottom: 2px;
+}
+.upload-card__meta {
+  font-size: 0.625rem;
+  color: var(--wutt-text-muted);
+}
+.upload-card__save {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  padding: 0.375rem 0.875rem;
+  font-family: inherit;
+  font-size: 0.6875rem;
+  font-weight: 600;
+  color: var(--wutt-light);
+  background: var(--wutt-dark);
+  border: none;
+  border-radius: var(--radius-full);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+  flex-shrink: 0;
+}
+.upload-card__save:hover { background: #2A2A2A; }
+.upload-card__save:active { transform: scale(0.96); }
+
+/* ---- Describe inline form (in chat) ---- */
+.describe-form {
+  display: flex;
+  flex-direction: column;
+  gap: var(--space-sm);
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border-light);
+  border-radius: var(--radius-lg);
+  padding: var(--space-md);
+  margin-top: var(--space-sm);
+  max-width: 320px;
+  animation: chatMsgIn 0.35s ease-out;
+}
+
+.describe-form__fields {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--space-sm);
+}
+
+.describe-form__field {
+  flex: 1;
+  min-width: 80px;
+  padding: 0.5rem 0.75rem;
+  font-family: inherit;
+  font-size: 0.6875rem;
+  color: var(--wutt-text);
+  background: var(--wutt-bg-subtle);
+  border: 1px solid var(--wutt-border);
+  border-radius: var(--radius-sm);
+  outline: none;
+  transition: border-color var(--transition-fast);
+}
+.describe-form__field::placeholder { color: var(--wutt-text-muted); }
+.describe-form__field:focus { border-color: var(--wutt-primary); }
+
+.describe-form__save {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 4px;
+  padding: 0.45rem 1rem;
+  font-family: inherit;
+  font-size: 0.6875rem;
+  font-weight: 600;
+  color: var(--wutt-light);
+  background: var(--wutt-dark);
+  border: none;
+  border-radius: var(--radius-full);
+  cursor: pointer;
+  transition: all var(--transition-fast);
+  width: 100%;
+}
+.describe-form__save:hover { background: #2A2A2A; }
+.describe-form__save:active { transform: scale(0.97); }
+
+/* ---- Wardrobe cards in sidebar ---- */
+.sidebar-wardrobe {
+  padding: var(--space-md);
+}
+
+.sidebar-wardrobe__title {
+  font-size: 0.6875rem;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 1px;
+  color: var(--wutt-text-muted);
+  margin-bottom: var(--space-sm);
+}
+
+.sidebar-wardrobe__grid {
+  display: flex;
+  flex-direction: column;
+  gap: var(--space-xs);
+  max-height: 360px;
+  overflow-y: auto;
+}
+
+.sidebar-wardrobe__item {
+  display: flex;
+  align-items: center;
+  gap: var(--space-sm);
+  padding: var(--space-sm);
+  background: var(--wutt-bg-subtle);
+  border-radius: var(--radius-sm);
+  transition: background var(--transition-fast);
+}
+.sidebar-wardrobe__item:hover { background: var(--wutt-bg); }
+
+.sidebar-wardrobe__thumb {
+  width: 36px;
+  height: 36px;
+  border-radius: 6px;
+  object-fit: cover;
+  background: var(--wutt-border-light);
+  flex-shrink: 0;
+}
+
+.sidebar-wardrobe__thumb--placeholder {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: var(--wutt-text-muted);
+  background: var(--wutt-border-light);
+}
+
+.sidebar-wardrobe__item-info {
+  flex: 1;
+  min-width: 0;
+}
+
+.sidebar-wardrobe__item-name {
+  font-size: 0.6875rem;
+  font-weight: 600;
+  color: var(--wutt-text);
+  line-height: 1.3;
+}
+
+.sidebar-wardrobe__item-cat {
+  font-size: 0.5625rem;
+  color: var(--wutt-text-muted);
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+}
+
+/* ---- Analyzing loader (in chat) ---- */
+.analyzing-card {
+  display: flex;
+  align-items: center;
+  gap: var(--space-md);
+  background: var(--wutt-light);
+  border: 2px dashed var(--wutt-border);
+  border-radius: var(--radius-lg);
+  padding: var(--space-lg) var(--space-md);
+  animation: chatMsgIn 0.35s ease-out;
+}
+.analyzing-card__spinner {
+  width: 32px;
+  height: 32px;
+  border: 3px solid var(--wutt-border);
+  border-top-color: var(--wutt-primary);
+  border-radius: 50%;
+  animation: spin 0.7s linear infinite;
+  flex-shrink: 0;
+}
+.analyzing-card__text {
+  font-size: var(--text-sm);
+  color: var(--wutt-text-light);
+  font-weight: 500;
+}
+.analyzing-card__dot {
+  display: inline-block;
+  animation: analyzingDots 1.4s steps(3, end) infinite;
+}
+
+@keyframes analyzingDots {
+  0%   { content: ''; }
+  33%  { opacity: 0.3; }
+  66%  { opacity: 0.6; }
+}
+
+/* ---- AI analysis result card ---- */
+/* ---- AI analysis draft card — compact fashion-item layout ---- */
+.analysis-card {
+  background: var(--wutt-light);
+  border: 1px solid var(--wutt-border-light);
+  border-radius: var(--radius-lg);
+  overflow: hidden;
+  animation: chatMsgIn 0.4s ease-out;
+  box-shadow: var(--shadow-sm);
+  width: fit-content;
+}
+
+.analysis-card__draft-badge {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  padding: 2px 7px;
+  font-size: 0.5rem;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+  color: var(--wutt-text-muted);
+  background: var(--wutt-bg-subtle);
+  border-radius: 99px;
+  margin-bottom: var(--space-xs);
+  width: fit-content;
+}
+.analysis-card__draft-badge svg { opacity: 0.5; }
+
+.analysis-card__body {
+  display: flex;
+  gap: var(--space-md);
+  padding: var(--space-md);
+  align-items: center;
+}
+
+.analysis-card__thumb {
+  width: 72px;
+  height: 72px;
+  border-radius: var(--radius-md);
+  object-fit: cover;
+  background: var(--wutt-bg-subtle);
+  flex-shrink: 0;
+}
+
+.analysis-card__thumb--placeholder {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: var(--wutt-text-muted);
+}
+
+.analysis-card__summary {
+  flex: 1;
+  min-width: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+
+.analysis-card__category {
+  font-size: 0.5625rem;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.6px;
+  color: var(--wutt-primary);
+}
+
+.analysis-card__item-name {
+  font-size: var(--text-base);
+  font-weight: 700;
+  color: var(--wutt-dark);
+  letter-spacing: -0.01em;
+  line-height: 1.3;
+}
+
+/* Compact inline pill fields — editable by clicking */
+.analysis-tags {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+  margin-top: 4px;
+}
+
+.analysis-tag {
+  display: inline-flex;
+  align-items: center;
+  gap: 3px;
+  padding: 3px 10px;
+  font-family: inherit;
+  font-size: 0.625rem;
+  font-weight: 500;
+  color: var(--wutt-text);
+  background: var(--wutt-bg-subtle);
+  border: 1px solid var(--wutt-border);
+  border-radius: 99px;
+  cursor: pointer;
+  transition: all var(--transition-fast);
+  outline: none;
+  min-width: 0;
+}
+.analysis-tag:hover {
+  background: var(--wutt-border-light);
+  border-color: var(--wutt-primary);
+}
+.analysis-tag:focus {
+  background: var(--wutt-light);
+  border-color: var(--wutt-primary);
+  box-shadow: 0 0 0 3px rgba(136, 162, 255, 0.1);
+  outline: none;
+}
+
+.analysis-tag__label {
+  font-size: 0.5rem;
+  font-weight: 600;
+  text-transform: uppercase;
+  letter-spacing: 0.4px;
+  color: var(--wutt-text-muted);
+  margin-right: 1px;
+}
+
+.analysis-card__footer {
+  display: flex;
+  gap: var(--space-sm);
+  padding: 0 var(--space-md) var(--space-md);
+  flex-wrap: wrap;
+}
+
+.analysis-card__save {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  padding: 0.45rem 1rem;
+  font-family: inherit;
+  font-size: 0.6875rem;
+  font-weight: 700;
+  color: var(--wutt-light);
+  background: var(--wutt-dark);
+  border: none;
+  border-radius: 99px;
+  cursor: pointer;
+  transition: all var(--transition-fast);
+}
+.analysis-card__save:hover { background: #2A2A2A; transform: translateY(-1px); }
+.analysis-card__save:active { transform: scale(0.97); }
+.analysis-card__save:disabled {
+  opacity: 0.5;
+  cursor: not-allowed;
+  transform: none;
+}
+
+.analysis-card__action-ghost {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  padding: 0.45rem 0.75rem;
+  font-family: inherit;
+  font-size: 0.625rem;
+  font-weight: 500;
+  color: var(--wutt-text-light);
+  background: transparent;
+  border: 1px solid var(--wutt-border);
+  border-radius: 99px;
+  cursor: pointer;
+  transition: all var(--transition-fast);
+}
+.analysis-card__action-ghost:hover {
+  background: var(--wutt-bg-subtle);
+  color: var(--wutt-text);
+}
+
+.sidebar-wardrobe__empty {
+  font-size: 0.625rem;
+  color: var(--wutt-text-muted);
+  text-align: center;
+  padding: var(--space-md);
+  line-height: 1.5;
+}
+
+/* ---- Wardrobe drawer ---- */
+.wardrobe-drawer {
+  width: 240px;
+  flex-shrink: 0;
+  background: var(--wutt-light);
+  border-right: 1px solid var(--wutt-border-light);
+  overflow-y: auto;
+  display: flex;
+  flex-direction: column;
+}
+.wardrobe-drawer__header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: var(--space-md);
+  border-bottom: 1px solid var(--wutt-border-light);
+}
+.wardrobe-drawer__title {
+  font-size: var(--text-sm);
+  font-weight: 700;
+  color: var(--wutt-dark);
+  letter-spacing: -0.01em;
+}
+.wardrobe-drawer__close {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  min-width: 28px;
+  min-height: 28px;
+  background: var(--wutt-bg-subtle);
+  border: none;
+  border-radius: var(--radius-full);
+  cursor: pointer;
+  color: var(--wutt-text-muted);
+}
+.wardrobe-drawer__close:hover { color: var(--wutt-text); background: rgba(0,0,0,0.05); }
+
+/* ---- Chat mood themes ---- */
+.chat-app--night {
+  --_chat-bg: #1a1817;
+  --_chat-surface: #242120;
+  --_chat-border: #302c2a;
+  --_chat-text: #e8e2da;
+  --_chat-muted: #908880;
+}
+.chat-app--night { background: var(--_chat-bg); }
+.chat-app--night .chat-sidebar { background: var(--_chat-surface); border-color: var(--_chat-border); }
+.chat-app--night .chat-sidebar__item { color: var(--_chat-muted); }
+.chat-app--night .chat-sidebar__item--active { color: #c8b4f0; background: rgba(200,180,240,0.12); }
+.chat-app--night .chat-header { background: rgba(36,33,32,0.85); border-color: var(--_chat-border); }
+.chat-app--night .chat-header__title { color: var(--_chat-text); }
+.chat-app--night .chat-header__subtitle { color: var(--_chat-muted); }
+.chat-app--night .chat-msg__bubble { background: var(--_chat-surface); border-color: var(--_chat-border); color: var(--_chat-text); }
+.chat-app--night .chat-msg--user .chat-msg__bubble { background: #3a3540; color: #e8e2da; }
