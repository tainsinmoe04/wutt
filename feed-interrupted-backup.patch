+/* ============================================================
+WUTT Style Quiz — final neutral smoky reference overlay
+Target: right/second reference card, no yellow tint
+============================================================ */
+
+.style-card {
+  border: none !important;
+  overflow: hidden !important;
+  background: #f3eee8 !important;
+}
+
+/* Neutral smoky full-card fade.
+No yellow, no cream, no blush, no pill, no hard line. */
+.style-card::before {
+  content: "" !important;
+  position: absolute !important;
+  inset: 0 !important;
+  z-index: 1 !important;
+  pointer-events: none !important;
+  border-radius: inherit !important;
 
-  .dashboard { padding-top: 70px; }
-  .dashboard__grid { grid-template-columns: 1fr; padding: var(--space-md); }
+  background:
+    linear-gradient(
+      to top,
+      rgba(8, 9, 10, 0.92) 0%,
+      rgba(10, 11, 12, 0.82) 14%,
+      rgba(12, 13, 14, 0.64) 28%,
+      rgba(18, 19, 20, 0.42) 42%,
+      rgba(24, 25, 26, 0.22) 54%,
+      rgba(28, 29, 30, 0.08) 64%,
+      rgba(28, 29, 30, 0) 72%
+    ) !important;
+
+  opacity: 1 !important;
+  filter: none !important;
+  backdrop-filter: none !important;
+  -webkit-backdrop-filter: none !important;
+}
+
+@media (hover: hover) and (pointer: fine) {
+  .style-card:hover {
+    transform: translate3d(0, -12px, 0) scale(1.02) rotateX(1.5deg) rotateY(-1deg) !important;
+  }
+}
 
-  .toast-container { left: var(--space-md); right: var(--space-md); max-width: 100%; }
+.style-card__visual {
+  inset: 0 !important;
+  overflow: hidden !important;
+  border-radius: inherit !important;
+  background: #f3eee8 !important;
+  z-index: 0 !important;
+}
+
+/* Keep black top image edge hidden and image sharp */
+.style-card__img,
+.style-card__visual img {
+  width: 100% !important;
+  height: 100% !important;
+  object-fit: cover !important;
+  object-position: center 10% !important;
+  transform: scale(1.09) translateY(-4px) !important;
+  transform-origin: center center !important;
+  filter: none !important;
+  backdrop-filter: none !important;
+  -webkit-backdrop-filter: none !important;
+}
+
+/* Hover must not blur or soften image */
+.style-card:hover .style-card__img,
+.style-card:hover .style-card__visual img {
+  transform: scale(1.09) translateY(-4px) !important;
+  filter: none !important;
+  backdrop-filter: none !important;
+  -webkit-backdrop-filter: none !important;
+}
+
+/* Disable all old overlay pseudo-elements that caused pill/line */
+.style-card__visual::before,
+.style-card__visual::after,
+.style-card__info::before,
+.style-card__info::after {
+  content: none !important;
+  display: none !important;
+}
+
+/* Text layer only — no background, no box, no line */
+.style-card__info {
+  position: absolute !important;
+  left: 0 !important;
+  right: 0 !important;
+  bottom: 0 !important;
+  z-index: 2 !important;
+
+  height: auto !important;
+  min-height: 0 !important;
+  padding: 0 18px 18px !important;
+
+  display: flex !important;
+  flex-direction: column !important;
+  justify-content: flex-end !important;
+  gap: 4px !important;
+
+  background: transparent !important;
+  border: none !important;
+  box-shadow: none !important;
+  overflow: visible !important;
+
+  backdrop-filter: none !important;
+  -webkit-backdrop-filter: none !important;
+  mask-image: none !important;
+  -webkit-mask-image: none !important;
+}
+
+/* Text should feel like reference card */
+.style-card__label,
+.style-card__tag {
+  position: relative !important;
+  z-index: 3 !important;
+}
+
+.style-card__label {
+  color: #ffffff !important;
+  font-weight: 800 !important;
+  letter-spacing: -0.02em !important;
+  text-shadow:
+    0 2px 14px rgba(0, 0, 0, 0.82),
+    0 0 1px rgba(0, 0, 0, 0.95) !important;
+}
+
+.style-card__tag {
+  color: rgba(255, 255, 255, 0.84) !important;
+  text-shadow:
+    0 1px 10px rgba(0, 0, 0, 0.72),
+    0 0 1px rgba(0, 0, 0, 0.85) !important;
+}
+
+/* Checkmark must stay above overlay */
+.style-card__check {
+  z-index: 4 !important;
+}
+
+/* Preserve selected state */
+.style-card[aria-pressed="true"] {
+  box-shadow:
+    inset 0 0 0 2px var(--wutt-primary),
+    0 2px 10px rgba(0, 0, 0, 0.04),
+    0 8px 28px rgba(0, 0, 0, 0.03) !important;
+}
+
+@media (hover: hover) and (pointer: fine) {
+  .style-card[aria-pressed="true"]:hover {
+    box-shadow:
+      inset 0 0 0 2px var(--wutt-primary),
+      0 22px 50px rgba(0, 0, 0, 0.14) !important;
+  }
 }
 
